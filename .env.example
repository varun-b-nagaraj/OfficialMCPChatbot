# Ollama
OLLAMA_BASE_URL=http://ollama.com
OLLAMA_MODEL=deepseek-v3.1:671b-cloud
OLLAMA_API_KEY=

# Zapier MCP
# You can set either full connect URL (with token query param) OR MCP_SERVER_URL + MCP_TOKEN.
MCP_CONNECT_URL=
MCP_SERVER_URL=https://mcp.zapier.com/api/v1/connect
MCP_TOKEN=

# Optional local/alternate MCP server config mode:
# If MCP_SERVER_NAME is set, the server is loaded from MCP_SERVER_CONFIG_PATH
# and used via stdio transport instead of MCP_CONNECT_URL/MCP_TOKEN.
MCP_SERVER_CONFIG_PATH=./mcp.servers.json
MCP_SERVER_NAME=

# Optional
MAX_TOOL_ROUNDS=8

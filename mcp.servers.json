{
  "mcpServers": {
    "everything": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-everything"]
    },
    "tuui Docs": {
      "command": "npx",
      "args": ["mcp-remote", "https://gitmcp.io/AI-QL/tuui"]
    },
    "antvis-chart": {
      "command": "npx",
      "args": ["-y", "@antv/mcp-server-chart"]
    },
    "google-connector": {
      "command": "/Users/varunbhadurgattenagaraj/Downloads/python-mcp-server/.venv/bin/python",
      "args": ["-m", "aios_cofounder_mcp.main"],
      "env": {
        "PYTHONPATH": "/Users/varunbhadurgattenagaraj/Downloads/python-mcp-server/src"
      }
    },
    "lightspeed-mcp": {
      "command": "npx",
      "args": ["-y", "mcp-remote", "https://mcp-lightspeedbackend.onrender.com"]
    },
    "CofounderMCP (local venv)": {
      "command": "/Users/varunbhadurgattenagaraj/Downloads/KoreOS_MCP_Backend/.venv/bin/python",
      "args": ["-m", "uvicorn", "app.main:app", "--host", "127.0.0.1", "--port", "8000"],
      "env": {
        "PYTHONPATH": "/Users/varunbhadurgattenagaraj/Downloads/KoreOS_MCP_Backend"
      }
    },
    "CofounderMCP (mcp-remote to local)": {
      "command": "npx",
      "args": ["mcp-remote", "http://127.0.0.1:8000/mcp"]
    },
    "CofounderMCP (Render)": {
      "command": "npx",
      "args": ["mcp-remote", "https://koreos-mcp-backend.onrender.com/mcp"]
    }
  }
}
